# Copy the variable NAMES below into your hosting provider's "Environment Variables"
# settings (e.g. Vercel → Project → Settings → Environment Variables).
# NEVER put real values in this file or commit real keys to any repo.

CASHFREE_APP_ID=your_app_id_here
CASHFREE_SECRET_KEY=your_secret_key_here
CASHFREE_ENV=production
SITE_URL=https://yourdomain.com
DOWNLOAD_LINK=https://your-file-host.com/direct-download-link
